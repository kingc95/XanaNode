{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xananode.org/schemas/substrate-manifest.schema.json",
  "title": "Substrate Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "version", "namespace", "repository"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "namespace": { "type": "string" },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "url", "default_branch"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["git"]
        },
        "url": { "type": "string" },
        "default_branch": { "type": "string" },
        "path": { "type": "string" },
        "commit": { "type": "string" }
      }
    },
    "description": { "type": "string" },
    "schema_version": { "type": "string" },
    "license": { "type": "string" },
    "maintainers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      }
    },
    "imports": {
      "type": "array",
      "items": { "type": "string" }
    },
    "extensions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
